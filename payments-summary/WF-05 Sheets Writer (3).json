    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// ============================================================\n// WF-05 [6] Confirmation Builder (v2.4)\n// Изменения v2.4: строка 🧾 invoice_number (только если не пустой)\n// ============================================================\n\nconst d = $('Generate Nr ID & Build Row').item.json;\n\n// --- Страна ---\nconst country = d.country || 'Беларусь';\nconst isPoland = (country === 'Польша');\n\n// Флаг страны\nconst flag = isPoland\n  ? '\\uD83C\\uDDF5\\uD83C\\uDDF1'  // 🇵🇱\n  : '\\uD83C\\uDDE7\\uD83C\\uDDFE'; // 🇧🇾\n\n// --- Путь Drive ---\nconst rootFolder = isPoland ? 'Poland' : 'Belarus';\nconst yearMonth  = d.periodLabel || '';\nconst subFolder  = d.status === 'Поступление' ? 'income' : 'outcome';\n\nconst driveLink = d.driveUrl\n  ? `\\n\\uD83D\\uDD17 [Ссылка на файл](${d.driveUrl})`\n  : '';\n\nconst folderHint = d.driveUrl\n  ? `\\n\\uD83D\\uDCC1 ${rootFolder}/${yearMonth}/${subFolder}/`\n  : '';\n\n// --- Сумма ---\nconst signedAmount = parseFloat(d.signedAmount);\nconst currency     = String(d.currency || '').toUpperCase();\nlet amountDisplay  = '\\u2014';\nif (!isNaN(signedAmount) && signedAmount !== 0) {\n  const sign = signedAmount >= 0 ? '+' : '-';\n  const abs  = Math.abs(signedAmount);\n  const formatted = Number.isInteger(abs) ? String(abs) : abs.toFixed(2);\n  amountDisplay = `${sign}${formatted}${currency ? ' ' + currency : ''}`;\n}\n\n// === v2.4: строка инвойса (только если поле не пустое) ===\nconst invoiceNumber = String(d.invoiceNumber || '').trim();\nconst invoiceLine   = invoiceNumber ? `\\n\\uD83E\\uDDFE ${invoiceNumber}` : '';\n\n// --- Шаблон подтверждения ---\nconst confirmationText =\n`\\u2705 Записано\n\n\\uD83D\\uDCCC ${d.nrId} | ${d.status || '\\u2014'}\n${flag} ${country}\n\\uD83D\\uDCC5 ${d.docDate || '\\u2014'}\n\\uD83C\\uDFE2 ${d.counterparty || '\\u2014'}${invoiceLine}\n\\uD83D\\uDCB0 ${amountDisplay} | ${d.payStatus || '\\u2014'}${folderHint}${driveLink}\n\n\\uD83D\\uDCAC ${d.aiDescription || ''}`;\n\nreturn {\n  json: {\n    nrId:             d.nrId,\n    uuid:             d.uuid,\n    chatId:           d.chatId || '',\n    confirmationText,\n    periodLabel:      d.periodLabel,\n    status:           d.status,\n    signedAmount,\n    currency,\n    country\n  }\n};\n"
      },
