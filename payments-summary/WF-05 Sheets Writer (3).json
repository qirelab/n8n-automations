      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// ============================================================\n// WF-05 [1] Resolve Current Period (YYYY.MM)\n// Приоритет: docDate из входа → текущая дата\n// ============================================================\n\nconst itemJson = $json;\nlet year, month;\n\nconst docDate = itemJson.docDate || '';\nconst parts = docDate.split('.');\nif (parts.length === 3 && parts[2] && parts[1]) {\n  month = parts[1].padStart(2, '0');\n  year = parts[2];\n} else {\n  const now = new Date();\n  month = String(now.getMonth() + 1).padStart(2, '0');\n  year = String(now.getFullYear());\n}\n\nconst periodLabel = `${year}.${month}`;\n\n// Нормализация страны (дефолт Беларусь)\nconst rawCountry = String(itemJson.country || '').trim();\nconst country = rawCountry === 'Польша' ? 'Польша' : 'Беларусь';\n\nreturn {\n  json: {\n    ...itemJson,\n    periodLabel,\n    periodYear: year,\n    periodMonth: month,\n    country\n  }\n};\n"
      },
