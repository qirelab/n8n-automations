    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// ============================================================\n// WF-05 [3] ID Generator + Row Builder (v2.4)\n// Изменения v2.4: добавлен invoice_number → колонка M реестра\n// ============================================================\n\nconst input = $('Resolve Period').item.json;\n\n// counterRow: либо из Get Counter Row (true-ветка), либо только что создана (false-ветка)\nlet counterRow;\ntry {\n  counterRow = $('Counter Row Exists?').item.json;\n} catch (e) {\n  counterRow = null;\n}\nif (!counterRow || !counterRow['Период']) {\n  counterRow = {\n    'Период': input.periodLabel,\n    'Страна': input.country || 'Беларусь',\n    'Поступления (0.XXXX)': 0,\n    'Выбытия (1.XXXX)': 0\n  };\n}\n\n// --- Тип операции (0 = Поступление, 1 = Выбытие) ---\nconst typeCode = input.status === 'Поступление' ? 0 : 1;\nconst counterKey = typeCode === 0 ? 'Поступления (0.XXXX)' : 'Выбытия (1.XXXX)';\n\n// --- Инкремент счётчика ---\nconst currentCount = parseInt(counterRow[counterKey] || '0', 10) || 0;\nconst newCount = currentCount + 1;\nconst nrId = `${typeCode}.${String(newCount).padStart(4, '0')}`;\n\n// --- UUID v4 ---\nconst uuid = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {\n  const r = Math.random() * 16 | 0;\n  const v = c === 'x' ? r : (r & 0x3 | 0x8);\n  return v.toString(16);\n});\n\n// --- Обновлённые значения счётчиков ---\nconst newIncome  = typeCode === 0 ? newCount : parseInt(counterRow['Поступления (0.XXXX)'] || '0', 10);\nconst newOutcome = typeCode === 1 ? newCount : parseInt(counterRow['Выбытия (1.XXXX)']     || '0', 10);\n\n// --- Обработка суммы (v2.3) ---\nconst rawAmt = input.amount;\nlet absAmount = 0;\nif (typeof rawAmt === 'number') {\n  absAmount = Math.abs(rawAmt);\n} else if (typeof rawAmt === 'string' && rawAmt.trim()) {\n  const parsed = parseFloat(rawAmt.replace(/[^0-9.,\\-]/g, '').replace(',', '.'));\n  absAmount = Math.abs(isNaN(parsed) ? 0 : parsed);\n}\n\nconst signedAmount = typeCode === 0 ? absAmount : -absAmount;\nconst currency = String(input.currency || '').toUpperCase();\n\n// === v2.4: invoice_number ===\nconst invoiceNumber = String(input.invoice_number || '').trim();\n\n// --- Сборка строки реестра (A–M видимые + L скрытый UUID) ---\nconst row = {\n  'Nr ID':              nrId,\n  'Статус':             input.status || '',\n  'Дата документа':     input.docDate || '',\n  'Контрагент':         input.counterparty || '',\n  'Дата оплаты':        input.payDate || '',\n  'Сумма':              signedAmount,\n  'Валюта':             currency,\n  'Статус оплаты':      input.payStatus || '',\n  'Страна':             input.country || 'Беларусь',\n  'Ссылка на документ': input.driveUrl || '',\n  'Описание AI':        input.aiDescription || '',\n  'UUID':               uuid,\n  'Номер инвойса':      invoiceNumber\n};\n\nreturn {\n  json: {\n    ...input,\n    nrId,\n    uuid,\n    invoiceNumber,\n    typeCode,\n    counterKey,\n    newCount,\n    newIncome,\n    newOutcome,\n    signedAmount,\n    currency,\n    registryRow: row\n  }\n};\n"
      },
