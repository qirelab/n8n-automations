    {
      "parameters": {
        "jsCode": "// Получаем ответ от HTTP Request к WF-02/03\nconst raw = $input.first().json;\nconst data = raw.confirmationText ? raw : (raw.data || raw.body || raw);\n\nif (!data.confirmationText) {\n  const prevChatId = $('Whitelist + Router').first().json.chatId;\n  return [{ json: {\n    chatId: prevChatId,\n    confirmationText: '⚠️ Ошибка обработки. Попробуйте ещё раз.'\n  }}];\n}\n\nreturn [{ json: {\n  chatId: String(data.chatId || $('Whitelist + Router').first().json.chatId),\n  confirmationText: data.confirmationText\n}}];"
      },
