    {
      "parameters": {
        "jsCode": "// === EVALUATE SESSION ===\n// Проверяет, активна ли сессия /vpsk для данного chatId.\n// Сессия активна только для файлов (photo/document), не для voice/text.\n// Входные данные: результат Check VPSK Session (строка из листа Сессии или пустой объект).\n// Оригинальные данные роутинга берём из Whitelist + Router.\n\nconst sessionData = $input.first().json;\nconst origData    = $('Whitelist + Router').first().json;\n\n// Сессия актуальна только для файлов\nconst isFile = (origData.type === 'photo' || origData.type === 'document');\n\nlet sessionActive = false;\nif (isFile && sessionData && sessionData.chat_id && sessionData.command === 'vpsk') {\n  try {\n    const expires = new Date(sessionData.expires_at);\n    if (expires > new Date()) sessionActive = true;\n  } catch (e) {}\n}\n\nreturn [{\n  json: {\n    ...origData,\n    _sessionRoute: sessionActive ? 1 : 0,\n    _sessionChatId: sessionData.chat_id || ''\n  }\n}];\n"
      },
