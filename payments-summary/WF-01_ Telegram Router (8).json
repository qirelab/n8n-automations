    {
      "parameters": {
        "jsCode": "// === WHITELIST + ROUTER (v2) ===\n// Правка аудита: photo mime_type не хардкодим в image/jpeg — Telegram может\n// прислать PNG-фото тоже; реальная MIME-нормализация делается в WF-02/03.\nconst allowed = ($env.TELEGRAM_ADMIN_CHAT_ID || '').split(',').map(id => id.trim());\nconst msg = $input.first().json.message || {};\nconst chatId = String(msg.chat?.id || '');\n\nif (!chatId || !allowed.includes(chatId)) {\n  return [];\n}\n\nlet outputIndex = 3;\nlet payload = { chatId };\n\nif (msg.photo && msg.photo.length > 0) {\n  outputIndex = 0;\n  payload.type = 'photo';\n  payload.file_id = msg.photo[msg.photo.length - 1].file_id;\n  payload.mime_type = 'image/jpeg'; // Telegram сжимает фото в JPEG, но WF-02/03 всё равно нормализует MIME по magic-bytes\n} else if (msg.document) {\n  const mime = msg.document.mime_type || 'application/octet-stream';\n  // Пропускаем любой документ — WF-02/03 сам выполнит MIME-нормализацию (NFR-11)\n  outputIndex = 0;\n  payload.type = 'document';\n  payload.file_id = msg.document.file_id;\n  payload.mime_type = mime;\n  payload.file_size = msg.document.file_size || 0;\n} else if (msg.voice) {\n  outputIndex = 0;\n  payload.type = 'voice';\n  payload.file_id = msg.voice.file_id;\n} else if (msg.text && msg.text.startsWith('/')) {\n  outputIndex = 1;\n  payload.text = msg.text;\n} else if (msg.text) {\n  outputIndex = 0;\n  payload.type = 'text';\n  payload.text = msg.text;\n}\n\npayload.outputIndex = outputIndex;\nreturn [{ json: payload }];"
      },
