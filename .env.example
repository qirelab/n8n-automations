# =============================================================
# n8n-automations — environment variables (example)
# Скопируйте этот файл в `.env` и заполните своими значениями.
# Никогда не коммитьте `.env` — он в .gitignore.
# =============================================================


# --- n8n: ядро ----------------------------------------------
# Ключ шифрования credentials внутри n8n. Сгенерировать один раз
# и НИКОГДА не менять (иначе слетят все сохранённые credentials).
N8N_ENCRYPTION_KEY=replace_with_long_random_string

# Публичный URL, на который Telegram (и другие сервисы) шлют webhooks.
WEBHOOK_URL=https://n8n.example.com/

# Сетевые настройки сервера n8n
N8N_HOST=n8n.example.com
N8N_PORT=5678
N8N_PROTOCOL=https

# Таймзона для cron-триггеров (автосверка и т.п.)
GENERIC_TIMEZONE=Europe/Minsk

# Хранилище бинарных файлов: filesystem | memory | s3
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_DATA_DIR=/home/node/.n8n

# Безопасность
N8N_SECURE_COOKIE=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Параллельные исполнения воркфлоу
EXECUTIONS_CONCURRENCY_LIMIT=10


# --- n8n: база данных (PostgreSQL) ---------------------------
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=replace_with_strong_password
DB_POSTGRESDB_SCHEMA=public


# --- Telegram ------------------------------------------------
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA_replace_with_real_token

# Whitelist Telegram chat_id (через запятую). Только эти пользователи
# могут писать боту. Узнать chat_id можно через @userinfobot.
TELEGRAM_ADMIN_CHAT_ID=111111111,222222222

# Алиас, используется в части воркфлоу/нод
ALLOWED_CHAT_IDS=111111111,222222222


# --- Google AI (Gemini) --------------------------------------
# API-ключ Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=replace_with_gemini_api_key

# Модель по умолчанию. Vision и Text используют разные модели —
# здесь задаётся базовая; см. ноды для уточнения.
GEMINI_MODEL_ID=gemini-2.5-flash


# --- Google Drive / Sheets -----------------------------------
# ID корневой папки на Drive для инвойсов/документов. Внутри неё WF-04
# создаёт подпапки по месяцам и типу: <ROOT>/YYYY.MM/income|outcome.
# Берётся из URL папки: drive.google.com/drive/folders/<ID>
GOOGLE_DRIVE_ROOT_ID=replace_with_drive_folder_id

# ID основной Google Sheets (Реестр + Счётчики + Банк + Сверка).
# Берётся из URL: docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEETS_ID=replace_with_main_sheets_id

# ID отдельной таблицы «Объединённый Реестр» для бухгалтерии (/update).
# Может совпадать с GOOGLE_SHEETS_ID или быть отдельным документом.
REGISTRY_SHEET_ID=replace_with_registry_sheets_id


# --- Gmail (опционально) -------------------------------------
# Сколько дней назад просматривать письма при поиске документов.
GMAIL_LOOKBACK_DAYS=7
