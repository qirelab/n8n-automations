        "text": "=❌ Не удалось сохранить запись дневника.\n\n*Шаг:* {{ $json.error?.node?.name || $json.node?.name || 'неизвестный' }}\n*Ошибка:* {{ $json.error?.message || $json.error?.description || ($json.error ? (typeof $json.error === 'string' ? $json.error : JSON.stringify($json.error)) : 'неизвестная ошибка') }}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "telegram-notify-error",
      "name": "Telegram Notify Error",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
