    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Извлекаем структурированный JSON из ответа OpenAI.\nconst raw = $json.message?.content ?? $json.content ?? $json.output ?? $json.text ?? $json;\nlet parsed;\nif (typeof raw === 'string') {\n  try {\n    parsed = JSON.parse(raw);\n  } catch (e) {\n    const match = raw.match(/\\{[\\s\\S]*\\}/);\n    if (!match) throw new Error('OpenAI did not return JSON: ' + raw);\n    parsed = JSON.parse(match[0]);\n  }\n} else {\n  parsed = raw;\n}\n\nreturn {\n  json: {\n    task: {\n      Наименование: parsed['Наименование'] ?? '',\n      Приоритет: parsed['Приоритет'] ?? '',\n      'Характер задач': parsed['Характер задач'] ?? '',\n      Время: parsed['Время'] ?? '',\n      Проект: parsed['Проект'] ?? '',\n      Сфера: parsed['Сфера'] ?? '',\n      Запланировано: parsed['Запланировано'] ?? '',\n      Комментарий: parsed['Комментарий'] ?? ''\n    },\n    chatId: $('Telegram Trigger (Voice)').item.json.message.chat.id,\n    transcript: $('OpenAI Transcribe (Whisper)').item.json.text\n  }\n};"
      },
      "id": "1c7c7f13-fcd8-420f-af57-d898a38ad9a5",
