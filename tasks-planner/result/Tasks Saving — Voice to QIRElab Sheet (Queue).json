    {
      "parameters": {
        "jsCode": "// Считаем max(Номер) из QIRElab и инкрементируем.\n// Если лист пустой — стартуем с 1.\nconst rows = $input.all();\nlet max = 0;\nfor (const r of rows) {\n  const n = Number(String(r.json['Номер'] ?? '').replace(',', '.'));\n  if (Number.isFinite(n) && n > max) max = n;\n}\nconst nextNumber = max + 1;\n\nconst parsed = $('Parse OpenAI JSON').first().json;\nconst task = parsed.task || {};\n\n// pairedItem нужен, чтобы n8n мог проследить линию данных от триггера —\n// иначе downstream-ноды (например, Telegram Notify Success) выдают\n// \"Paired item data ... unavailable\" при обращении через $('...').item.\nreturn [{\n  json: {\n    Номер: nextNumber,\n    Наименование: task['Наименование'] ?? '',\n    Приоритет: task['Приоритет'] ?? '',\n    'Характер задач': task['Характер задач'] ?? '',\n    Время: task['Время'] ?? '',\n    Проект: task['Проект'] ?? '',\n    Сфера: task['Сфера'] ?? '',\n    Запланировано: task['Запланировано'] ?? '',\n    Комментарий: task['Комментарий'] ?? '',\n    chatId: parsed.chatId,\n    transcript: parsed.transcript || ''\n  },\n  pairedItem: { item: 0 }\n}];"
      },
